# ==========================================
# NEXUS AI - .gitignore
# ==========================================

# -----------------------
# Python
# -----------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

# -----------------------
# Virtual Environment
# -----------------------
.venv/
venv/

# -----------------------
# Environment Variables
# -----------------------
.env

# -----------------------
# Logs
# -----------------------
logs/
*.log

# -----------------------
# Runtime Data
# -----------------------
data/*
!data/.gitkeep
!data/screenshots/
data/screenshots/*
!data/screenshots/.gitkeep

# -----------------------
# Tool Caches
# -----------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------
# Build Artifacts
# -----------------------
build/
dist/
*.egg-info/
.eggs/

# -----------------------
# Coverage
# -----------------------
.coverage
htmlcov/

# -----------------------
# IDE
# -----------------------
.vscode/
.idea/

# -----------------------
# macOS
# -----------------------
.DS_Store

# -----------------------
# Jupyter
# -----------------------
.ipynb_checkpoints/